# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WebSocket Server
WS_SERVER_URL=ws://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Music Pipeline
MUSIC_PIPELINE_ROOT=C:\Users\SANDY\Music
MUSIC_PIPELINE_DRY_RUN=true
MUSIC_PIPELINE_EXTRACT_ARCHIVES=false
MUSIC_PIPELINE_ORGANIZE=false
MUSIC_PIPELINE_MOVE_CORRUPTED=false
MUSIC_PIPELINE_UPLOAD=false
MUSIC_PIPELINE_INSERT_DB=false
MUSIC_PIPELINE_CLOUD_PROVIDER=none
MUSIC_PIPELINE_DATABASE_PROVIDER=none
MUSIC_PIPELINE_SUPABASE_BUCKET=songs
MUSIC_PIPELINE_STORAGE_PREFIX=music-assets
MUSIC_PIPELINE_PARALLELISM=4
MUSIC_PIPELINE_UPLOAD_PARALLELISM=3
MUSIC_PIPELINE_MAX_ARCHIVE_DEPTH=3
MUSIC_PIPELINE_ARCHIVE_RETRIES=2
MUSIC_PIPELINE_API_TOKEN=change_me_to_a_long_random_secret

# Admin upload portal
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
ADMIN_SESSION_SECRET=change_me_to_a_long_random_session_secret

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=
